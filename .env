# 默认配置 —— 提交到 git，作为项目默认值
# 本地覆盖请使用 .env.local（不会被 git 跟踪）

# 适配层对外端口（Cherry Studio 填这个）
PORT=11435

# Ollama 服务地址
OLLAMA_BASE_URL=http://localhost:11434

# Ollama 中用于 Rerank 的模型
OLLAMA_MODEL=dengcao/Qwen3-Reranker-8B:Q5_K_M

# Ollama chat API 路径
OLLAMA_CHAT_PATH=/api/chat

# Rerank 拦截路径（逗号分隔——Cherry Studio OpenAI 和 Ollama 提供商各一种）
RERANK_PATHS=/v1/rerank,/api/v1/rerank

# 单次 Ollama 请求超时 (ms)
OLLAMA_TIMEOUT_MS=60000

# 最大并发 Ollama 请求数
MAX_CONCURRENCY=4

# 日志目录（不设则自动选择：prod → C:\ProgramData\forward-reranker-port\logs，dev → ./logs）
# LOGS_DIR=

# 数据目录（telemetry.db — 不设则与日志同规则：prod → C:\ProgramData\forward-reranker-port，dev → ./data）
# DATA_DIR=
